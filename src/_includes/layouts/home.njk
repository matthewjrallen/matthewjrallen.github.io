---
layout: "layouts/base.njk"
---

<section class="hero">

	<div class="section-label"><span class="mono">01 /</span> Introduction</div>

	<h1 class="hero-title">Matthew<br/><em>Allen</em></h1>

	<div class="hero-right">
		
		<div class="hero-desc">

			{{ content | safe }}

		</div>
		
		<div class="hero-actions">

			<a href="projects.html" class="btn-primary">View Projects</a>

			<a href="contact.html" class="btn-ghost">Get in Touch</a>

		</div>

	</div>

</section>

<div class="divider"></div>

<section class="skills-section">

	<div class="section-label"><span class="mono">02 /</span> Expertise</div>

	<div class="skills-grid">

		<div class="skill-block">

			<h3>Frontend</h3>

			<ul>
				<li>HTML</li>
				<li>CSS</li>
				<li>Javascript</li>
				<li>On-page SEO</li>
				<li>Performance Optimization</li>
			</ul>

		</div>

		<div class="skill-block">

			<h3>Backend</h3>

			<ul>
				<li>PHP</li>
				<li>MYSQL</li>
				<li>Wordpress</li>
				<li>Woocommerce</li>
			</ul>

		</div>

		<div class="skill-block">

			<h3>Tooling</h3>

			<ul>
				<li>Git & GitHub</li>
				<li>Figma</li>
				<li>Adobe Creative Suite</li>
				<li>VS Code</li>
				<li>Terminal</li>
			</ul>

		</div>

	</div>

</section>

<div class="divider"></div>

<section class="projects-section">

    <div class="section-label"><span class="mono">03 /</span> Selected Projects</div>

    <div class="projects-grid">

		{% for post in collections.projects | reverse %}
			
			{% if post.data.public %}
				
				{% include 'partials/entry.njk' %}
				
			{% endif %}
			
		{% endfor %}

	</div>

</section>