---
layout: "layouts/base.njk"
---

<section class="page-header">
    
	<div class="section-label"><span class="mono">01 /</span> Projects</div>
    
	<h1 class="page-title">Selected <em>Work</em></h1>
    
	<p class="page-subtitle">{{ subtitle }}</p>

</section>

<div class="divider"></div>

<section class="projects-list">

	{% set projectIndex = 0 %}

    {% for post in collections.projects | reverse %}
		
		{% if post.data.public %}

			{% set projectIndex = projectIndex + 1 %}

			{% include 'partials/project.njk' %}
			
		{% endif %}
		
	{% endfor %}

</section>